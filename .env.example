TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional
GEMINI_MODEL=gemini-2.5-flash
DATABASE_PATH=assistant.sqlite3
HISTORY_LIMIT=20
MAX_RESPONSE_CHARS=3500

# Optional for Vercel webhook mode
TELEGRAM_WEBHOOK_SECRET=change_me_to_a_long_random_string
VERCEL_APP_URL=https://your-app.vercel.app
CRON_SECRET=change_me_to_a_different_long_random_string
APP_TIMEZONE=Asia/Qyzylorda
